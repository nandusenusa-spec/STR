# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: webhooks / bypass RLS (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# App URL for checkout redirects and webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Política de privacidad (URL pública HTTPS). Meta / Facebook App Dashboard → "Privacy Policy URL".
# Si está vacío, el sitio usa la página /privacidad. Si ponés una URL absoluta (ej. Notion o PDF), el footer enlaza ahí.
NEXT_PUBLIC_PRIVACY_POLICY_URL=

# Mercado Pago (optional — without token checkout returns success URL mock)
MERCADOPAGO_ACCESS_TOKEN=
# Webhook HMAC secret (Notifications → Webhooks → signing secret). Rejects forged callbacks.
MERCADOPAGO_WEBHOOK_SECRET=

# Checkout currency (UYU for Uruguay, ARS if you prefer)
NEXT_PUBLIC_MP_CURRENCY_ID=UYU

# Opcional: URL exacta del callback OAuth (mismo origen que producción). Si no va, se usa NEXT_PUBLIC_APP_URL + /auth/callback
# En Supabase → Auth → Redirect URLs: https://TU_DOMINIO/auth/callback y http://localhost:3000/auth/callback
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Opcional: emails que reciben fila en admin_profiles al iniciar sesión (coma-separados). Misma lógica en login.
NEXT_PUBLIC_ADMIN_EMAILS=

# Optional distributed rate limiting (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional SOC alerting webhook (Slack/Discord/custom webhook expecting {text})
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_WEBHOOK_BEARER=

# Burst detection for warning events
SECURITY_WARNING_WINDOW_MINUTES=10
SECURITY_WARNING_BURST_THRESHOLD=25

# --- Moderación de contenido (opcional en dev; recomendado en producción) ---
# Texto: lista extra separada por comas (minúsculas), se suma a la lista base en el servidor.
# MODERATION_EXTRA_TERMS=

# Imágenes: una de las dos (si ninguna, las imágenes no se escanean por IA en el servidor).
# OpenAI — moderación multimodal (omni-moderation-latest)
# OPENAI_API_KEY=
# Sightengine — https://sightengine.com (api_user + api_secret)
# SIGHTENGINE_API_USER=
# SIGHTENGINE_API_SECRET=

# Clave extra para abrir /admin después de estar en admin_profiles (default en código: str2026 si no se define)
# ADMIN_PANEL_PASSWORD=
